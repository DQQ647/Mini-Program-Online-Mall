/* 苹果风格全局样式 */
page {
  background-color: #f5f5f7;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  color: #1d1d1f;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 苹果卡片 */
.ios-card {
  background: #fff;
  border-radius: 16px;
  padding: 16px;
  margin: 12px 16px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
  transition: 0.2s;
}
.ios-card:active {
  transform: scale(0.98);
  opacity: 0.95;
}

/* 苹果按钮 */
.ios-btn {
  background: #007aff;
  color: #fff;
  border-radius: 12px;
  padding: 12px 20px;
  font-weight: 500;
  border: none;
  text-align: center;
}
.ios-btn:active {
  opacity: 0.8;
}

/* 价格 */
.price {
  color: #007aff;
  font-size: 18px;
  font-weight: bold;
}

/* 标签 */
.tag {
  position: absolute;
  top: 10px;
  left: 10px;
  background: #ff3b30;
  color: #fff;
  font-size: 12px;
  padding: 4px 8px;
  border-radius: 12px;
}