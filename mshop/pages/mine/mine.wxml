<view class="container">

<!-- 顶部用户区域 -->
<view class="user-card">
  <!-- 未登录：可点击按钮 -->
  <view wx:if="{{!isLogin}}" bindtap="goLogin">
    <text class="login-text">点击登录</text>
  </view>

  <!-- 已登录：显示头像 + 名字 -->
  <view wx:else class="user-info">
    <image src="{{userInfo.avatarUrl}}" class="avatar"></image>
    <text class="nickname">{{userInfo.nickName}}</text>
  </view>
</view>

<!-- 我的订单 -->
<view class="box">
  <view class="box-title">我的订单</view>
  <view class="order-list">
    <view class="item">
      <text class="icon">📦</text>
      <text>待发货</text>
    </view>
    <view class="item">
      <text class="icon">🚚</text>
      <text>待收货</text>
    </view>
    <view class="item">
      <text class="icon">✅</text>
      <text>已完成</text>
    </view>
    <view class="item">
      <text class="icon">📋</text>
      <text>全部订单</text>
    </view>
  </view>
</view>

<!-- 功能菜单 -->
<view class="menu-box">
  <view class="menu-item" bindtap="goAddress">
    <view class="menu-left">
      <text class="menu-icon">📍</text>
      <text class="menu-title">收货地址</text>
    </view>
    <text class="menu-arrow">></text>
  </view>

  <view class="menu-item" bindtap="goService">
    <view class="menu-left">
      <text class="menu-icon">💬</text>
      <text class="menu-title">联系客服</text>
    </view>
    <text class="menu-arrow">></text>
  </view>

  <view class="menu-item" bindtap="goAbout">
    <view class="menu-left">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-title">关于我们</text>
    </view>
    <text class="menu-arrow">></text>
  </view>
</view>

<!-- 退出登录 -->
<view wx:if="{{isLogin}}" class="logout" bindtap="logout">
  退出登录
</view>

</view>