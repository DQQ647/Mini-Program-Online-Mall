<view class="container">
  <!-- 头部用户信息区域（保留你原来的样式） -->
  <view class="header" bindtap="{{isLogin ? '' : 'goLogin'}}">
    <view class="avatar">
      <!-- 已登录显示用户头像，未登录显示默认头像 -->
      <image src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
    </view>
    <view class="username">{{userInfo.nickName || '微信用户'}}</view>
  </view>

  <!-- 我的订单模块（保留你原来的图标和布局） -->
  <view class="order-section">
    <view class="title">我的订单</view>
    <view class="order-list">
      <view class="order-item" bindtap="goOrderList" data-status="0">
        <view class="icon">📦</view>
        <text>待发货</text>
      </view>
      <view class="order-item" bindtap="goOrderList" data-status="1">
        <view class="icon">🚚</view>
        <text>待收货</text>
      </view>
      <view class="order-item" bindtap="goOrderList" data-status="2">
        <view class="icon">✅</view>
        <text>已完成</text>
      </view>
      <view class="order-item" bindtap="goOrderList" data-status="all">
        <view class="icon">📋</view>
        <text>全部订单</text>
      </view>
    </view>
  </view>

  <!-- 功能列表（和你界面完全一致） -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goAddress">
      <view class="icon">📍</view>
      <text>收货地址</text>
      <view class="arrow">></view>
    </view>
    <view class="menu-item" bindtap="goService">
      <view class="icon">💬</view>
      <text>联系客服</text>
      <view class="arrow">></view>
    </view>
    <view class="menu-item" bindtap="goAbout">
      <view class="icon">ℹ️</view>
      <text>关于我们</text>
      <view class="arrow">></view>
    </view>
  </view>

  <!-- 退出登录按钮（未登录时隐藏，已登录时显示） -->
  <view wx:if="{{isLogin}}" class="logout-btn" bindtap="logout">退出登录</view>
</view>