/* pages/mine/mine.wxss */
.mine-page {
  background: #f5f5f7;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #0071e3, #5856d6);
  color: #fff;
  padding: 60rpx 30rpx 40rpx;
  text-align: center;
  border-radius: 0 0 40rpx 40rpx;
  margin-bottom: 30rpx;
}
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.3);
}
.username {
  font-size: 36rpx;
  font-weight: bold;
  margin-top: 20rpx;
}
.user-desc {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 10rpx;
}

/* 板块标题 */
.section {
  padding: 0 30rpx;
  margin-bottom: 30rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1d1d1f;
  margin-bottom: 20rpx;
}

/* 订单模块 */
.order-box {
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  padding: 40rpx 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.order-item {
  flex: 1;
  text-align: center;
}
.icon {
  font-size: 40rpx;
  display: block;
  margin-bottom: 10rpx;
}
.label {
  font-size: 24rpx;
  color: #1d1d1f;
}

/* 菜单列表 */
.menu-list {
  background: #fff;
  border-radius: 24rpx;
  margin: 0 30rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  font-size: 28rpx;
  color: #1d1d1f;
  border-bottom: 1rpx solid #f5f5f7;
}
.menu-item:last-child {
  border-bottom: none;
}
.arrow {
  color: #86868b;
  font-size: 32rpx;
}
.menu-item.red {
  color: #ff3b30;
  justify-content: center;
  font-weight: 500;
}