page {
  background: #f7f3f0;
  font-family: PingFangSC, sans-serif;
}
.container {
  padding: 30rpx;
}
/* 头部用户信息 */
.header {
  background: #d4b9a8;
  border-radius: 24rpx;
  padding: 40rpx 0;
  text-align: center;
  margin-bottom: 30rpx;
}
.avatar image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
}
.username {
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
}
/* 订单模块 */
.order-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}
.title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 30rpx;
  color: #333;
}
.order-list {
  display: flex;
  justify-content: space-around;
}
.order-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 26rpx;
  color: #666;
}
.order-item .icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}
/* 功能列表 */
.menu-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 0 30rpx;
  margin-bottom: 30rpx;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0ebe6;
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-item .icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}
.menu-item text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}
.arrow {
  color: #ccc;
  font-size: 28rpx;
}
/* 退出登录按钮 */
.logout-btn {
  background: #fff;
  border-radius: 24rpx;
  text-align: center;
  padding: 30rpx;
  font-size: 30rpx;
  color: #d4b9a8;
}