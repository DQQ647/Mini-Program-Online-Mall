.container{
  background:#f5f5f7;
  min-height:100vh;
}
.top-box{
  padding:40rpx;
  text-align:center;
}
.top-img{
  width:100%;
  height:300rpx;
  border-radius:24rpx;
  margin-bottom:30rpx;
}
.title{
  font-size:36rpx;
  font-weight:bold;
  margin-bottom:10rpx;
}
.desc{
  color:#888;
  font-size:26rpx;
}
.list{
  padding:0 30rpx;
}
.item{
  background:#fff;
  padding:30rpx;
  border-radius:16rpx;
  margin-bottom:20rpx;
}