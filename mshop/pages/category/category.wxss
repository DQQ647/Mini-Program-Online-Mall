page {
  background-color: #f8f5f2;
}

.container {
  display: flex;
  height: 100vh;
}

/* 左侧导航 */
.left-nav {
  width: 220rpx;
  background-color: #fff;
}

.nav-item {
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
}

.nav-item.active {
  background-color: #f8f5f2;
  color: #c9a886;
  font-weight: bold;
}

/* 右侧商品区 */
.goods-container {
  flex: 1;
  padding: 20rpx;
}

.goods-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.goods-card {
  width: 330rpx;
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.goods-img {
  width: 100%;
  height: 330rpx;
}

.goods-info {
  padding: 20rpx;
}

.goods-title {
  display: block;
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.goods-price {
  display: block;
  font-size: 30rpx;
  color: #d9534f;
  font-weight: bold;
  margin-top: 10rpx;
}