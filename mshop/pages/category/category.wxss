page {
  background-color: #f8f5f2;
  /* 给顶部导航栏留出空间，防止按钮和系统导航重叠 */
  padding-top: 100rpx;
}

.container {
  display: flex;
  height: calc(100vh - 100rpx);
}

/* 左侧导航 */
.left-nav {
  width: 220rpx;
  background-color: #fff;
}

.nav-item {
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
}

.nav-item.active {
  background-color: #f8f5f2;
  color: #c9a886;
  font-weight: bold;
}

/* 右侧商品区 */
.goods-container {
  flex: 1;
  padding: 20rpx;
}

.goods-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.goods-card {
  width: 330rpx;
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.goods-img {
  width: 100%;
  height: 330rpx;
}

.goods-info {
  padding: 20rpx;
}

.goods-title {
  display: block;
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.goods-price {
  display: block;
  font-size: 30rpx;
  color: #d9534f;
  font-weight: bold;
  margin-top: 10rpx;
}

/* 返回首页按钮 - 调整位置不遮挡文字 */
.back-btn {
  position: fixed;
  top: 30rpx;
  left: 30rpx;
  z-index: 999;
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}
.back-icon {
  font-size: 36rpx;
  color: #666;
  font-weight: bold;
}