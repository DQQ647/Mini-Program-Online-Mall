page {
  background: #f2f2f7;
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
}

.container {
  display: flex;
  height: 100vh;
}

.left {
  width: 180rpx;
  background: #fff;
}

.item {
  text-align: center;
  padding: 30rpx 0;
  font-size: 26rpx;
  color: #666;
}

.item.active {
  color: #007aff;
  font-weight: 600;
  background: #f2f2f7;
  border-left: 4rpx solid #007aff;
}

.right {
  flex: 1;
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.04);
}

.img {
  width: 100%;
  height: 300rpx;
  border-radius: 16rpx;
  background: #f9f9f9;
}

.info {
  margin-top: 20rpx;
}

.title {
  font-size: 26rpx;
  color: #1d1d1f;
  line-height: 1.4;
}

.price {
  font-size: 30rpx;
  color: #007aff;
  font-weight: 600;
  margin: 16rpx 0;
  display: block;
}

.btn {
  background: #007aff;
  color: #fff;
  border-radius: 12rpx;
  font-size: 24rpx;
  padding: 0;
  width: 240rpx;
  height: 66rpx;
  line-height: 66rpx;
}

.btn::after {
  border: none;
}