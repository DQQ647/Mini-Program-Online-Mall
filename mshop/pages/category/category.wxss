page {
  background: #f7f3f0;
  font-family: PingFangSC, sans-serif;
}
.container {
  display: flex;
  height: 100vh;
}

/* 左侧分类 */
.left-bar {
  width: 180rpx;
  background: #ffffff;
  height: 100%;
}
.cate-item {
  padding: 30rpx 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666;
  position: relative;
}
.cate-item.active {
  color: #3d3530;
  font-weight: bold;
  background: #f7f3f0;
}
.cate-item.active::before {
  content: "";
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 40rpx;
  background: #d4b9a8;
  border-radius: 0 10rpx 10rpx 0;
}

/* 右侧商品 */
.right-goods {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.goods-card {
  width: 310rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx;
}
.goods-img {
  width: 100%;
  height: 220rpx;
  border-radius: 16rpx;
  background: #f5f0ec;
}
.goods-name {
  font-size: 26rpx;
  color: #3d3530;
  margin: 10rpx 0;
}
.goods-price {
  font-size: 28rpx;
  color: #c1695f;
  font-weight: bold;
}