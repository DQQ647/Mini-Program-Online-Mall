.cate-page {
  display: flex;
  height: 100vh;
  background: #f5f5f7;
}

.left-cate {
  width: 200rpx;
  background: #fff;
}

.cate-item {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 28rpx;
  border-left: 6rpx solid transparent;
  color: #1d1d1f;
}

.cate-item.active {
  background: #f5f5f7;
  border-left: 6rpx solid #0071e3;
  color: #0071e3;
  font-weight: 600;
}

.right-goods {
  flex: 1;
  padding: 30rpx;
}

.goods-item {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.05);
}

.goods-img {
  width: 220rpx;
  height: 220rpx;
  margin: 0 auto 20rpx;
}

.goods-name {
  font-size: 30rpx;
  color: #1d1d1f;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.goods-price {
  font-size: 32rpx;
  color: #0071e3;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.add-cart {
  background: #0071e3;
  color: #fff;
  border-radius: 50rpx;
  font-size: 26rpx;
  padding: 14rpx 36rpx;
  border: none;
}