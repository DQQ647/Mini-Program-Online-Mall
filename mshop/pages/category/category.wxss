page {
  background-color: #ffffff;
  height: 100vh;
  display: flex;
  flex-direction: column; /* 🌟 改为垂直流布局，让导航栏和内容区上下排布 */
  overflow: hidden;
}

/* ==========================
   🌟 自定义顶部导航栏样式 🌟
   ========================== */
.custom-header {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  /* padding-top 强行撑开状态栏高度（适配各种刘海屏） */
  padding: 90rpx 30rpx 20rpx; 
  background-color: #ffffff;
  border-bottom: 1rpx solid #f5f5f5;
  z-index: 99;
}

.back-action {
  display: flex;
  align-items: center;
  color: #333;
  padding: 10rpx 20rpx 10rpx 0;
}

.back-arrow {
  font-size: 38rpx;
  margin-right: 8rpx;
  font-weight: 400;
  margin-top: -4rpx;
}

.back-text {
  font-size: 30rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.header-placeholder {
  width: 100rpx; /* 与 back-action 宽度近似，确保 title 完美居中 */
}

/* ==========================
   主体容器
   ========================== */
.container {
  flex: 1; /* 占据屏幕剩余的所有高度 */
  display: flex;
  height: 0; /* Flex 滚动黑科技，防止被内容撑爆 */
}

/* 左侧侧边栏 */
.sidebar {
  width: 180rpx;
  background-color: #f7f8fa;
  height: 100%;
}

.nav-item {
  height: 110rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.2s;
}

.nav-text {
  font-size: 26rpx;
  color: #666;
}

.nav-item.active {
  background-color: #ffffff;
}

.nav-item.active .nav-text {
  color: #333;
  font-weight: bold;
}

.indicator {
  position: absolute;
  left: 0;
  width: 8rpx;
  height: 32rpx;
  background-color: #c9a886;
  border-radius: 0 4rpx 4rpx 0;
}

/* 右侧商品区 */
.goods-scroll {
  flex: 1;
  background-color: #ffffff;
  height: 100%;
}

.header-box {
  padding: 30rpx 30rpx 20rpx; /* 因为有了顶部导航，这里恢复正常的内边距 */
  display: flex;
  align-items: center; 
  border-bottom: 1rpx solid #fcfcfc;
}

.cate-title {
  font-size: 32rpx; 
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
  line-height: 1.5; 
}

.cate-count {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
  padding-top: 6rpx; 
}

.goods-list {
  padding: 0 20rpx;
}

.goods-item {
  display: flex;
  padding: 30rpx 10rpx;
  border-bottom: 1rpx solid #f5f5f5; 
}

.goods-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  background-color: #f9f9f9;
  margin-right: 24rpx;
  flex-shrink: 0; 
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 6rpx 0;
}

.goods-title {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2; 
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.price-box {
  color: #ff4d4f; 
}

.currency {
  font-size: 22rpx;
  margin-right: 2rpx;
  font-weight: bold;
}

.price {
  font-size: 36rpx;
  font-weight: bold;
}

.cart-icon {
  width: 44rpx;
  height: 44rpx;
  padding: 10rpx; 
  margin-right: -10rpx; 
}

.empty-state {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #ccc;
}

.safe-bottom {
  height: 120rpx;
}