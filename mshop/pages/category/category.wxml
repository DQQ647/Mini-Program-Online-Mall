<view class="container">
  <scroll-view class="left" scroll-y>
    <view class="item {{activeTag == item.tag ? 'active' : ''}}"
      wx:for="{{cateList}}" wx:key="tag"
      bindtap="switchCate" data-tag="{{item.tag}}">
      {{item.name}}
    </view>
  </scroll-view>

  <scroll-view class="right" scroll-y>
    <view class="card" wx:for="{{showGoods}}" wx:key="id">
      <image src="{{item.url}}" class="img" mode="aspectFill"></image>
      <view class="info">
        <text class="title">{{item.title}}</text>
        <text class="price">¥{{item.price}}</text>
        <button class="btn" bindtap="addToCart" data-item="{{item}}">加入购物车</button>
      </view>
    </view>
  </scroll-view>
</view>