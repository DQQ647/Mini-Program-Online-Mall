<view class="container">
  <scroll-view class="left-nav" scroll-y>
    <view 
      wx:for="{{cateList}}" 
      wx:key="type"
      class="nav-item {{currentIndex === index ? 'active' : ''}}"
      bindtap="switchCate"
      data-index="{{index}}"
    >
      {{item.name}}
    </view>
  </scroll-view>

  <scroll-view class="goods-container" scroll-y>
    <view class="goods-grid">
      <view 
        wx:for="{{goodsList}}" 
        wx:key="id"
        class="goods-card"
        bindtap="goDetail"
        data-id="{{item.id}}"
      >
        <image class="goods-img" src="{{item.url}}" mode="aspectFill"></image>
        <view class="goods-info">
          <text class="goods-title">{{item.title}}</text>
          <text class="goods-price">¥{{item.price}}</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>