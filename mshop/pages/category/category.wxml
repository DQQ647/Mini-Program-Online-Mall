<view class="container">
  <!-- 左侧分类 -->
  <view class="left-bar">
    <view 
      class="cate-item {{currentIndex==index?'active':''}}" 
      wx:for="{{cateList}}" 
      wx:key="index"
      bindtap="switchCate"
      data-index="{{index}}"
    >
      {{item.name}}
    </view>
  </view>

  <!-- 右侧商品 -->
  <view class="right-goods">
    <view 
      class="goods-card" 
      wx:for="{{goodsList}}" 
      wx:key="id"
      bindtap="goDetail"
      data-id="{{item.id}}"
    >
      <image src="{{item.url}}" class="goods-img"></image>
      <view class="goods-name">{{item.name}}</view>
      <view class="goods-price">¥{{item.price}}</view>
    </view>
  </view>
</view>