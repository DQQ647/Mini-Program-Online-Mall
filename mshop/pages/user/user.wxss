.container {
  background: #f5f5f5;
  min-height: 100vh;
}
.user-info {
  background: #fff;
  padding: 40rpx;
  display: flex;
  align-items: center;
}
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}
.nickname {
  font-size: 32rpx;
  margin-left: 30rpx;
  color: #333;
}
.menu-list {
  background: #fff;
  margin-top: 20rpx;
}
.menu-item {
  padding: 30rpx;
  font-size: 28rpx;
  border-bottom: 1rpx solid #eee;
}