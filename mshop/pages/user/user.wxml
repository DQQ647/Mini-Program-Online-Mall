<!-- 个人信息卡片 -->
<view class="ios-card" style="display:flex;align-items:center;justify-content:center;flex-direction:column;padding:24px 16px;">
  <image src="/images/avatar.png" style="width:80px;height:80px;border-radius:50%;background:#f2f2f7;"></image>
  <view style="margin-top:12px;">
    <view style="font-size:18px;font-weight:600;text-align:center;">Apple User</view>
    <view style="color:#8e8e93;font-size:14px;text-align:center;margin-top:4px;">Apple 生态爱好者</view>
  </view>
</view>

<!-- 功能列表（可点击） -->
<view class="ios-card" style="margin-top:16px;">
  <view class="menu-item" bindtap="goToOrder">
    <view style="display:flex;align-items:center;">
      <text style="margin-right:12px;">🛒</text>
      <text>我的订单</text>
    </view>
    <text style="color:#8e8e93;">></text>
  </view>
  <view class="menu-item" bindtap="goToDevice">
    <view style="display:flex;align-items:center;">
      <text style="margin-right:12px;">📱</text>
      <text>我的设备</text>
    </view>
    <text style="color:#8e8e93;">></text>
  </view>
  <view class="menu-item" bindtap="goToFavorite">
    <view style="display:flex;align-items:center;">
      <text style="margin-right:12px;">⭐</text>
      <text>我的收藏</text>
    </view>
    <text style="color:#8e8e93;">></text>
  </view>
  <view class="menu-item" bindtap="goToAddress">
    <view style="display:flex;align-items:center;">
      <text style="margin-right:12px;">📦</text>
      <text>收货地址</text>
    </view>
    <text style="color:#8e8e93;">></text>
  </view>
  <view class="menu-item" bindtap="goToSettings">
    <view style="display:flex;align-items:center;">
      <text style="margin-right:12px;">⚙️</text>
      <text>账户设置</text>
    </view>
    <text style="color:#8e8e93;">></text>
  </view>
  <view class="menu-item" bindtap="goToAbout">
    <view style="display:flex;align-items:center;">
      <text style="margin-right:12px;">ℹ️</text>
      <text>关于商城</text>
    </view>
    <text style="color:#8e8e93;">></text>
  </view>
</view>

<!-- 退出登录按钮 -->
<view style="margin:24px 16px;">
  <button style="width:100%;background:#fff;color:#ff3b30;border-radius:12px;padding:12px 0;border:none;font-size:16px;" bindtap="logout">退出登录</button>
</view>