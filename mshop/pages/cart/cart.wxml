<!--pages/cart/cart.wxml-->
<view class="container">
  <view wx:if="{{cartList.length === 0}}" class="empty-box">
    <view class="empty-text">购物车是空的</view>
    <view class="empty-desc">添加商品后显示在这里</view>
  </view>

  <view wx:else>
    <view class="ios-card" wx:for="{{cartList}}" wx:key="id">
      <view style="display:flex;align-items:center;">
        <image src="{{item.image}}" style="width:120rpx;height:120rpx;border-radius:16rpx;"></image>
        <view style="margin-left:20rpx;flex:1;">
          <view style="font-size:28rpx;">{{item.name}}</view>
          <view style="color:#007aff;font-size:28rpx;margin-top:10rpx;">¥{{item.price}}</view>
        </view>
      </view>
    </view>
  </view>
</view>