<view class="container">
  <!-- 购物车商品列表 -->
  <view class="cart-list">
    <view class="cart-item" wx:for="{{cartList}}" wx:key="id">
      <image class="goods-img" src="http://localhost:3001/images/goods/{{item.id}}.webp" />
      <view class="goods-info">
        <view class="goods-name">{{item.title}}</view>
        <view class="goods-price">¥{{item.price}}</view>
        <view class="num-control">
          <text class="btn minus" bindtap="changeNum" data-id="{{item.id}}" data-type="minus">-</text>
          <text class="num">{{item.num}}</text>
          <text class="btn plus" bindtap="changeNum" data-id="{{item.id}}" data-type="plus">+</text>
        </view>
      </view>
      <view class="delete-btn" bindtap="deleteGoods" data-id="{{item.id}}">删除</view>
    </view>
  </view>

  <!-- 空购物车提示（只有为空时才显示） -->
  <view wx:if="{{cartList.length === 0}}" class="empty-tip">
    购物车为空
  </view>

  <!-- 底部结算栏 -->
  <view class="bottom-bar" wx:if="{{cartList.length > 0}}">
    <view class="total">合计：¥{{totalPrice}}</view>
    <view class="check-btn" bindtap="goCheckout">去结算</view>
  </view>
</view>