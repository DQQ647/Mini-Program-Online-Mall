/* pages/cart/cart.wxss */
.container {
  background: #f5f5f7;
  min-height: 100vh;
  padding: 20rpx;
}

.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.empty-text {
  font-size: 30rpx;
  color: #1d1d1f;
}
.empty-desc {
  font-size: 24rpx;
  color: #8e8e93;
  margin-top: 20rpx;
}

.ios-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}