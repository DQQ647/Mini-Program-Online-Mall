.container {
  background: #f5f5f7;
  min-height: 100vh;
  padding: 20rpx;
}
.empty-box {
  text-align: center;
  margin-top: 200rpx;
}
.empty-text {
  font-size: 30rpx;
  color: #1d1d1f;
}
.empty-desc {
  font-size: 24rpx;
  color: #888;
  margin-top: 10rpx;
}
.ios-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
}
.del-btn {
  background: #ff3b30;
  color: #fff;
  font-size: 24rpx;
  border-radius: 12rpx;
  padding: 10rpx 20rpx;
  border: none;
}