page {
  background: #f7f3f0;
}
.container {
  padding-bottom: 120rpx;
}
.cart-item {
  background: #fff;
  border-radius: 24rpx;
  margin: 20rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
}
.cart-item image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
}
.info {
  flex: 1;
}
.title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}
.price {
  font-size: 30rpx;
  color: #d4b9a8;
}
.del {
  color: #ff4444;
  font-size: 26rpx;
  padding: 10rpx;
}
.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100rpx;
  background: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx;
  box-sizing: border-box;
  border-top: 1rpx solid #eee;
}
.total {
  font-size: 30rpx;
  color: #d4b9a8;
  font-weight: bold;
}
.buy {
  width: 200rpx;
  height: 70rpx;
  background: #d4b9a8;
  color: #fff;
  text-align: center;
  line-height: 70rpx;
  border-radius: 35rpx;
  font-size: 28rpx;
}