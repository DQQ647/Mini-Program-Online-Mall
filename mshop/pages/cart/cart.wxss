page {
  background: #f2f2f7;
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.cart-list {
  flex: 1;
  padding: 20rpx;
}

.item {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: #f9f9f9;
  margin-right: 20rpx;
}

.info {
  flex: 1;
}

.title {
  font-size: 26rpx;
  color: #1d1d1f;
}

.price {
  font-size: 28rpx;
  color: #007aff;
  font-weight: 600;
  margin-top: 8rpx;
  display: block;
}

.del {
  color: #ff3b30;
  font-size: 24rpx;
}

.empty {
  text-align: center;
  padding-top: 200rpx;
  color: #999;
}

.bottom {
  background: #fff;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.total {
  font-size: 28rpx;
  color: #007aff;
  font-weight: 600;
}

.buy {
  background: #007aff;
  color: #fff;
  border-radius: 12rpx;
  padding: 0 30rpx;
}