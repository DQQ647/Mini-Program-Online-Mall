.container {
  background: #f5f5f7;
  min-height: 100vh;
  padding: 40rpx;
}

.about-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1d1d1f;
  display: block;
  margin-bottom: 20rpx;
}

.info {
  font-size: 26rpx;
  color: #86868b;
  display: block;
  margin-bottom: 10rpx;
}