.container {
  background: #f5f5f7;
  min-height: 100vh;
  padding: 20rpx;
}

/* 订单卡片 */
.order-item {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f7;
}
.order-id {
  font-size: 26rpx;
  color: #86868b;
}
.order-status {
  font-size: 26rpx;
  padding: 8rpx 16rpx;
  border-radius: 10rpx;
}
.wait { color: #ff9500; background: #fff7e6; }
.ing { color: #007aff; background: #e6f3ff; }
.done { color: #34c759; background: #e6ffed; }

/* 商品列表 */
.goods-list {
  padding: 20rpx 30rpx;
}
.goods-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.goods-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background: #f5f5f7;
}
.goods-info {
  flex: 1;
}
.goods-name {
  font-size: 28rpx;
  color: #1d1d1f;
  display: block;
  margin-bottom: 10rpx;
}
.goods-price {
  font-size: 26rpx;
  color: #ff3b30;
}

/* 订单底部 */
.order-footer {
  text-align: right;
  padding: 20rpx 30rpx 30rpx;
  border-top: 1rpx solid #f5f5f7;
}
.total {
  font-size: 28rpx;
  color: #1d1d1f;
}

/* 空状态 */
.empty {
  text-align: center;
  padding-top: 200rpx;
}
.empty-img {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}
.empty-text {
  font-size: 28rpx;
  color: #86868b;
}