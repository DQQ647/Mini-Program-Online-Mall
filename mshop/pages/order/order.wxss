page {
  background: #f7f3f0;
}
.container {
  padding: 20rpx;
}
.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 25rpx 0;
  font-size: 26rpx;
  color: #666;
}
.tab.active {
  color: #d4b9a8;
  font-weight: 600;
}
.order-list {
  padding-bottom: 40rpx;
}
.order-item {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}
.order-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.order-no {
  font-size: 26rpx;
  color: #666;
}
.status {
  font-size: 26rpx;
  color: #d4b9a8;
}
.goods-item {
  display: flex;
  margin-bottom: 20rpx;
}
.goods-item image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}
.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.name {
  font-size: 28rpx;
  color: #333;
}
.price {
  font-size: 28rpx;
  color: #d4b9a8;
}
.order-footer {
  text-align: right;
}
.total {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 15rpx;
}
.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.receive-btn {
  display: inline-block;
  padding: 10rpx 20rpx;
  border: 1rpx solid #d4b9a8;
  color: #d4b9a8;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-top: 10rpx;
}

/* 已完成按钮组 */
.btn-group {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 10rpx;
}
.del-btn {
  padding: 10rpx 20rpx;
  border: 1rpx solid #999;
  color: #999;
  border-radius: 8rpx;
  font-size: 24rpx;
}
.buy-btn {
  padding: 10rpx 20rpx;
  background: #d4b9a8;
  color: #fff;
  border-radius: 8rpx;
  font-size: 24rpx;
}