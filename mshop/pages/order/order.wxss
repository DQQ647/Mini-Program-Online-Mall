page {
  background-color: #f8f9fa;
}

/* 导航栏样式 */
.tab-bar {
  display: flex;
  background: #ffffff;
  padding: 10rpx 0;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.02);
}

.tab {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #888;
  padding: 20rpx 0;
  transition: all 0.3s;
}

.tab.active {
  color: #333;
  font-weight: bold;
  position: relative;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 30rpx;
  height: 6rpx;
  background: #c9a886;
  border-radius: 10rpx;
}

/* 订单卡片样式 */
.order-scroll {
  height: calc(100vh - 100rpx);
  padding: 20rpx;
  box-sizing: border-box;
}

.order-card {
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.03);
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.order-no {
  font-size: 24rpx;
  color: #999;
}

.status-tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.status-0 { background: #fff5e6; color: #ffa940; } /* 待支付-暖橙 */
.status-1 { background: #e6f7ff; color: #1890ff; } /* 待收货-天蓝 */
.status-2 { background: #f6ffed; color: #52c41a; } /* 已完成-草绿 */

/* 卡片主体 */
.card-body {
  display: flex;
  margin-bottom: 30rpx;
}

.goods-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  margin-right: 24rpx;
}

.goods-detail {
  flex: 1;
}

.goods-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.4;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-spec {
  font-size: 22rpx;
  color: #bbb;
  margin-bottom: 16rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
}

.unit { font-size: 24rpx; color: #333; margin-right: 4rpx; }
.price { font-size: 32rpx; font-weight: bold; color: #333; }
.num { font-size: 24rpx; color: #999; margin-left: auto; }

/* 卡片底部 */
.card-footer {
  border-top: 1rpx solid #f8f8f8;
  padding-top: 24rpx;
}

.total-info {
  text-align: right;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 24rpx;
}

.total-price {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  margin-left: 10rpx;
}

/* 按钮组 */
.action-btns {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

.btn {
  padding: 14rpx 36rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  transition: opacity 0.2s;
}

.btn:active { opacity: 0.7; }

.btn-primary {
  background: #c9a886;
  color: #fff;
}

.btn-outline {
  border: 1rpx solid #c9a886;
  color: #c9a886;
}

.btn-default {
  border: 1rpx solid #eee;
  color: #999;
}

/* 空状态 */
.empty-holder {
  padding-top: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon { font-size: 100rpx; margin-bottom: 30rpx; opacity: 0.5; }
.empty-text { font-size: 28rpx; color: #ccc; margin-bottom: 40rpx; }
.empty-btn {
  background: #c9a886;
  color: #fff;
  padding: 20rpx 80rpx;
  border-radius: 50rpx;
}