page {
  background: #f7f3f0;
}

.container {
  padding-bottom: 120rpx;
}

/* 商品主图 */
.goods-img image {
  width: 100%;
  height: 600rpx;
}

/* 价格+标题 */
.info-box {
  background: #fff;
  border-radius: 24rpx;
  margin: 20rpx;
  padding: 30rpx;
}
.price {
  font-size: 40rpx;
  color: #d4b9a8;
  font-weight: bold;
  margin-bottom: 10rpx;
}
.title {
  font-size: 30rpx;
  color: #333;
}

/* 商品详情 */
.detail-box {
  background: #fff;
  border-radius: 24rpx;
  margin: 20rpx;
  padding: 30rpx;
}
.detail-title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 20rpx;
}
.detail-content image {
  width: 100%;
  margin-bottom: 10rpx;
  border-radius: 12rpx;
}

/* 底部购物车按钮 */
.cart-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100rpx;
  background: #fff;
  display: flex;
  justify-content: center;
  align-items: center;
  border-top: 1rpx solid #eee;
}
.add-cart {
  width: 90%;
  height: 70rpx;
  background: #d4b9a8;
  color: #fff;
  text-align: center;
  line-height: 70rpx;
  border-radius: 35rpx;
  font-size: 28rpx;
}