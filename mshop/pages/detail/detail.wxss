.container {
  background: #f5f5f5;
  padding-bottom: 120rpx;
}
.detail-img {
  width: 100%;
  height: 600rpx;
}
.info {
  background: #fff;
  padding: 30rpx;
  margin-top: 20rpx;
}
.title {
  font-size: 32rpx;
  color: #333;
}
.price {
  font-size: 36rpx;
  color: #ff4d4f;
  font-weight: bold;
  margin-top: 20rpx;
}
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 0 30rpx;
}
.add-cart {
  background: #ff4d4f;
  color: #fff;
  border-radius: 50rpx;
  font-size: 28rpx;
  padding: 0 60rpx;
}