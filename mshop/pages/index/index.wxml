<view class="container">

<!-- 轮播 -->
<swiper class="banner" indicator-dots circular autoplay>
  <swiper-item wx:for="{{bannerList}}" wx:key="id">
    <image src="{{item.url}}" class="banner-img"></image>
  </swiper-item>
</swiper>

<!-- 标题 -->
<view class="title">全部产品</view>

<!-- 左右结构商品列表 -->
<view class="goods-list">
  <view class="item" wx:for="{{goodsList}}" wx:key="id">
    <image src="{{item.image}}" class="item-img"></image>
    <view class="item-info">
      <view class="item-name">{{item.name}}</view>
      <view class="item-desc">{{item.desc}}</view>
      <view class="item-price">¥{{item.price}}</view>
      <button class="add-btn" bindtap="addCart" data-item="{{item}}">加入购物车</button>
    </view>
  </view>
</view>

</view>