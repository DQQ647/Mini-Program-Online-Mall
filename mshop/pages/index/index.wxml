<view class="container">
  <swiper class="banner" indicator-dots circular autoplay style="border-radius:16px;overflow:hidden;margin:12px 16px;">
    <swiper-item wx:for="{{bannerList}}" wx:key="id">
      <image src="{{item.url}}" class="banner-img" style="width:100%;height:180px;display:block;"></image>
    </swiper-item>
  </swiper>

  <view class="title" style="font-size:18px;font-weight:600;padding:0 16px;margin:16px 0;">全部产品</view>

  <view class="goods-list">
    <view class="item ios-card" wx:for="{{goodsList}}" wx:key="id" style="position:relative;">
      <view class="tag">热卖</view>
      <image src="{{item.image}}" class="item-img" style="width:100%;height:200px;border-radius:12px;display:block;"></image>
      <view class="item-info" style="margin-top:12px;">
        <view class="item-name" style="font-size:16px;font-weight:500;">{{item.name}}</view>
        <view class="item-desc" style="color:#8e8e93;font-size:14px;margin-top:4px;">{{item.desc}}</view>
        <view style="display:flex;justify-content:space-between;align-items:center;margin-top:12px;">
          <view class="item-price price">¥{{item.price}}</view>
          <button class="add-btn ios-btn" bindtap="addCart" data-item="{{item}}" style="padding:8px 16px;font-size:14px;">加入购物车</button>
        </view>
      </view>
    </view>
  </view>
</view>