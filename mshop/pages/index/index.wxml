<!--pages/index/index.wxml-->
<view class="container">

<!-- 苹果风格大轮播广告 -->
<swiper class="ios-swiper" indicator-dots autoplay circular>
  <swiper-item>
    <view class="ad-item ad-black">
      <view class="ad-title">iPhone 16 Pro</view>
      <view class="ad-sub">强力出圈</view>
      <view class="ad-link">进一步了解 ></view>
    </view>
  </swiper-item>

  <swiper-item>
    <view class="ad-item ad-white">
      <view class="ad-title">MacBook Pro</view>
      <view class="ad-sub">强劲，更进一步</view>
      <view class="ad-link">进一步了解 ></view>
    </view>
  </swiper-item>

  <swiper-item>
    <view class="ad-item ad-blue">
      <view class="ad-title">AirPods Pro</view>
      <view class="ad-sub">沉浸听觉体验</view>
      <view class="ad-link">进一步了解 ></view>
    </view>
  </swiper-item>
</swiper>

<!-- 功能入口 -->
<view class="grid-box">
  <view class="grid-item">
    <text class="icon">📱</text>
    <text>手机</text>
  </view>
  <view class="grid-item">
    <text class="icon">💻</text>
    <text>电脑</text>
  </view>
  <view class="grid-item">
    <text class="icon">🎧</text>
    <text>耳机</text>
  </view>
  <view class="grid-item">
    <text class="icon">⌚</text>
    <text>手表</text>
  </view>
</view>

<!-- 推荐卡片区 -->
<view class="section">
  <view class="section-title">热门推荐</view>

  <view class="ios-card card-big">
    <view class="card-text">
      <view class="card-title">教育优惠</view>
      <view class="card-desc">学生专享福利</view>
    </view>
  </view>

  <view class="ios-card card-big">
    <view class="card-text">
      <view class="card-title">以旧换新</view>
      <view class="card-desc">高价回收</view>
    </view>
  </view>
</view>

</view>