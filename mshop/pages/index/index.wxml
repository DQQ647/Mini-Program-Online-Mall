<!--pages/index/index.wxml-->
<view class="container">

<!-- 苹果官网风格轮播，三款产品 -->
<swiper class="ios-swiper" indicator-dots autoplay circular>
  <!-- iPhone 17 Pro -->
  <swiper-item>
    <image 
      src="https://images.unsplash.com/photo-1695048133142-1a20484d2569?w=800&h=600&fit=crop" 
      class="banner-img" 
      mode="aspectFill"
    ></image>
  </swiper-item>

  <!-- MacBook Air -->
  <swiper-item>
    <image 
      src="https://images.unsplash.com/photo-1517336714731-489689fd1ca8?w=800&h=600&fit=crop" 
      class="banner-img" 
      mode="aspectFill"
    ></image>
  </swiper-item>

  <!-- AirPods Pro 3 -->
  <swiper-item>
    <image 
      src="https://images.unsplash.com/photo-1600294037681-c80b4cb5b434?w=800&h=600&fit=crop" 
      class="banner-img" 
      mode="aspectFill"
    ></image>
  </swiper-item>
</swiper>

<!-- 热门推荐 -->
<view class="section">
  <view class="section-title">热门推荐</view>

  <view class="ios-card card-big card-edu">
    <image class="card-bg" src="https://picsum.photos/id/180/800/400" mode="aspectFill"></image>
    <view class="card-text card-text-white">
      <view class="card-title">教育优惠</view>
      <view class="card-desc">学生专享福利</view>
    </view>
  </view>

  <view class="ios-card card-big card-recycle">
    <image class="card-bg" src="https://picsum.photos/id/160/800/400" mode="aspectFill"></image>
    <view class="card-text card-text-dark">
      <view class="card-title">以旧换新</view>
      <view class="card-desc">高价回收</view>
    </view>
  </view>
</view>

<!-- 👇 这里是新增的底部区域，填补空白，不动你上面任何代码 -->
<view class="section">
  <view class="section-title">专属服务</view>
  <view class="service-box">
    <view class="service-card">
      <text class="service-title">官方正品</text>
      <text class="service-sub">全国联保</text>
    </view>
    <view class="service-card">
      <text class="service-title">送货上门</text>
      <text class="service-sub">极速配送</text>
    </view>
  </view>
</view>

</view>