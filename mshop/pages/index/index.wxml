<view class="home-wrap">
  <!-- 顶部轮播广告 -->
  <swiper class="ad-swiper" indicator-dots autoplay circular interval="3000">
    <swiper-item wx:for="{{swiperList}}" wx:key="id">
      <image src="{{item.url}}" mode="aspectFill" class="ad-img" />
    </swiper-item>
  </swiper>

  <!-- 苹果风分割标题 -->
  <view class="title-line">
    <text class="title-text">Apple 精选数码</text>
  </view>

  <!-- 单品广告区块 - iPhone -->
  <view class="ad-card card-1">
    <view class="ad-text">
      <text class="ad-main">iPhone 17 Pro</text>
      <text class="ad-sub">超强芯片 · 专业影像系统</text>
    </view>
  </view>

  <!-- 单品广告区块 - 电脑 -->
  <view class="ad-card card-2">
    <view class="ad-text">
      <text class="ad-main">MacBook Air</text>
      <text class="ad-sub">轻薄机身 · 超长续航</text>
    </view>
  </view>

  <!-- 单品广告区块 - 配件 -->
  <view class="ad-card card-3">
    <view class="ad-text">
      <text class="ad-main">智能配件全家桶</text>
      <text class="ad-sub">氮化镓快充 · 无线外设</text>
    </view>
  </view>

  <!-- 底部留白 -->
  <view class="space"></view>
</view>