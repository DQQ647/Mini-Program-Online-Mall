<view class="container">
  <!-- 轮播 -->
  <swiper class="banner" indicator-dots autoplay circular>
    <swiper-item wx:for="{{swiperList}}" wx:key="id">
      <image src="{{item.url}}" mode="aspectFill" />
    </swiper-item>
  </swiper>

  <!-- 以旧换新卡片 -->
  <view class="card-box" bindtap="goToRecycle">
    <view class="card-text">
      <text class="title">以旧换新</text>
      <text class="desc">高价回收旧设备 · 一站式便捷服务</text>
    </view>
  </view>

  <!-- 商品列表 → 左右结构 -->
  <view class="goods-title">精选商品</view>
  <view class="goods-list">
    <view class="item" wx:for="{{goodsList}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <!-- 左：图片 -->
      <image src="{{item.url}}" class="item-img" mode="aspectFill" />
      
      <!-- 右：文字信息 -->
      <view class="item-info">
        <text class="item-name">{{item.title}}</text>
        <text class="item-price">¥{{item.price}}</text>
      </view>
    </view>
  </view>
</view>