page {
  background: #f2f2f7;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.container {
  padding: 0 20rpx;
}

/* 轮播 */
.banner {
  width: 100%;
  height: 380rpx;
  border-radius: 20rpx;
  overflow: hidden;
  margin: 20rpx 0;
}
.banner image {
  width: 100%;
  height: 100%;
}

/* 苹果卡片 */
.card-box {
  background: #fff;
  border-radius: 22rpx;
  padding: 35rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.05);
}
.card-text .title {
  font-size: 32rpx;
  font-weight: 600;
  color: #000;
}
.card-text .desc {
  font-size: 24rpx;
  color: #8e8e93;
  margin-top: 8rpx;
  display: block;
}

/* 商品标题 */
.goods-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: #1c1c1e;
}

/* 左右结构商品列表 */
.goods-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.04);
}

/* 左边图片 */
.item-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  background: #f9f9f9;
  margin-right: 20rpx;
}

/* 右边文字 */
.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.item-name {
  font-size: 26rpx;
  color: #1c1c1e;
  line-height: 1.4;
}
.item-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #007aff;
}