page {
  background-color: #f5f5f7;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
  margin: 0;
  padding: 0;
}
.home-wrap {
  padding: 0 24rpx;
}

/* 顶部轮播广告 */
.ad-swiper {
  width: 100%;
  height: 420rpx;
  border-radius: 28rpx;
  overflow: hidden;
  margin: 30rpx 0;
}
.ad-img {
  width: 100%;
  height: 100%;
}

/* 分割标题 */
.title-line {
  margin: 40rpx 0 20rpx;
}
.title-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #1d1d1f;
}

/* 广告通用卡片 */
.ad-card {
  width: 100%;
  height: 280rpx;
  border-radius: 28rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: flex-end;
  padding: 40rpx;
  box-sizing: border-box;
}
.card-1 {
  background: linear-gradient(135deg, #f0f0f2, #e4e4e6);
}
.card-2 {
  background: linear-gradient(135deg, #e2e8f0, #d1d9e3);
}
.card-3 {
  background: linear-gradient(135deg, #f8f3f0, #f0e8e2);
}

.ad-main {
  font-size: 36rpx;
  font-weight: 600;
  color: #1d1d1f;
  display: block;
}
.ad-sub {
  font-size: 26rpx;
  color: #6e6e73;
  margin-top: 12rpx;
}

.space {
  height: 100rpx;
}