page {
  background: #f5f5f7;
}

.container {
  width: 100%;
  padding-bottom: 60rpx;
}

/* 轮播 */
.banner {
  width: 100%;
  height: 440rpx;
}
.banner-img {
  width: 100%;
  height: 100%;
}

/* 标题 */
.title {
  font-size: 42rpx;
  font-weight: 600;
  color: #1d1d1f;
  padding: 40rpx 30rpx 20rpx;
}

/* 左右结构商品 */
.goods-list {
  padding: 0 24rpx;
}

.item {
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.04);
}

.item-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 20rpx;
  margin-right: 30rpx;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.item-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #1d1d1f;
  margin-bottom: 8rpx;
}

.item-desc {
  font-size: 24rpx;
  color: #86868b;
  margin-bottom: 12rpx;
}

.item-price {
  font-size: 34rpx;
  color: #0071e3;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.add-btn {
  width: 220rpx;
  height: 60rpx;
  line-height: 60rpx;
  background: #0071e3;
  color: #fff;
  border-radius: 30rpx;
  font-size: 24rpx;
}