.container {
  background: #f5f5f7;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 轮播容器 */
.ios-swiper {
  width: 100%;
  height: 400rpx;
}

/* 轮播图片 */
.banner-img {
  width: 100%;
  height: 100%;
}

/* 轮播文字 */
.banner-text {
  position: absolute;
  bottom: 40rpx;
  left: 0;
  right: 0;
  text-align: center;
  color: #fff;
}
.banner-dark {
  color: #1d1d1f;
}
.banner-title {
  font-size: 36rpx;
  font-weight: bold;
}
.banner-sub {
  font-size: 24rpx;
  margin-top: 10rpx;
  opacity: 0.9;
}

/* 推荐卡片 */
.section {
  padding: 20rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #1d1d1f;
}

.ios-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 0;
  margin-bottom: 20rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
}
.card-big {
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-bg {
  position: absolute;
  top:0; left:0;
  width:100%; height:100%;
  opacity:0.8;
}

/* 卡片文字 */
.card-text {
  position: relative;
  z-index: 1;
  text-align: center;
}
.card-text-white {
  color: #fff;
}
.card-text-dark {
  color: #1d1d1f;
}
.card-title {
  font-size: 32rpx;
  font-weight: bold;
}
.card-desc {
  font-size: 24rpx;
  margin-top: 10rpx;
  opacity: 0.9;
}

/* 专属服务 */
.service-box {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}
.service-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}
.service-title {
  font-size: 28rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
  color: #1d1d1f;
}
.service-sub {
  font-size: 22rpx;
  color: #666;
}