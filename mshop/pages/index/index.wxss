/* pages/index/index.wxss */
.container {
  background: #f5f5f7;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.ios-swiper {
  width: 100%;
  height: 360rpx;
}

.ad-item {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.ad-black {
  background: #000;
  color: #fff;
}
.ad-white {
  background: #f5f5f7;
  color: #1d1d1f;
}
.ad-blue {
  background: #007aff;
  color: #fff;
}

.ad-title {
  font-size: 36rpx;
  font-weight: bold;
}
.ad-sub {
  font-size: 24rpx;
  margin-top: 10rpx;
  opacity: 0.8;
}
.ad-link {
  font-size: 24rpx;
  margin-top: 20rpx;
  color: #007aff;
}

.grid-box {
  display: flex;
  padding: 20rpx;
}
.grid-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
}
.icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.section {
  padding: 20rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.ios-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
}
.card-big {
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.card-title {
  font-size: 32rpx;
  font-weight: bold;
}
.card-desc {
  font-size: 24rpx;
  color: #8e8e93;
  margin-top: 10rpx;
}