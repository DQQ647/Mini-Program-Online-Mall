.container {
  padding: 20rpx;
  background-color: #f5f5f5;
}

/* 导航样式 */
.nav-box {
  display: flex;
  flex-wrap: wrap;
  background: #ffffff;
  padding: 20rpx 0;
  border-radius: 16rpx;
  margin: 20rpx 0;
}
.nav-item {
  width: 25%;
  text-align: center;
  font-size: 26rpx;
  color: #333;
  margin-bottom: 20rpx;
}

/* 商品列表样式 */
.goods-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.item {
  width: 48%;
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}
.pic {
  width: 100%;
  height: 300rpx;
}
.info {
  padding: 20rpx;
}
.name {
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.price {
  font-size: 28rpx;
  color: #ff4d4f;
  font-weight: bold;
  margin-top: 10rpx;
  display: block;
}