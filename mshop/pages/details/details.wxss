.container{padding:30rpx;background:#fff;min-height:100vh;}
.goods-img{width:100%;border-radius:16rpx;}
.title{font-size:36rpx;font-weight:bold;margin-top:20rpx;color:#333;}
.price{font-size:44rpx;color:#ff3333;margin:20rpx 0;font-weight:bold;}
.desc{font-size:28rpx;color:#666;line-height:1.6;}

.num-row{
  display:flex;justify-content:space-between;align-items:center;
  padding:20rpx 0;border-top:1rpx solid #eee;margin-top:20rpx;
}
.num-box{display:flex;align-items:center;}
.num-box .btn{
  width:60rpx;height:60rpx;line-height:60rpx;text-align:center;
  background:#f5f5f5;border-radius:8rpx;font-size:32rpx;
}
.num-box .num{width:80rpx;text-align:center;font-size:30rpx;}

.btn-row{
  display:flex;gap:20rpx;margin-top:40rpx;
}
.btn{
  flex:1;text-align:center;padding:26rpx;border-radius:12rpx;font-size:32rpx;
}
.btn.cart{background:#ff9900;color:#fff;}
.btn.buy{background:#ff3333;color:#fff;}