page {
  background: #f7f3f0;
}

.container {
  padding-bottom: 130rpx;
}

.main-img {
  width: 100%;
  height: 500rpx;
}

.info {
  background: #fff;
  border-radius: 24rpx;
  margin: 20rpx;
  padding: 30rpx;
}

.title {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 15rpx;
}

.price {
  font-size: 42rpx;
  color: #d4b9a8;
  font-weight: bold;
}

.detail-section {
  background: #fff;
  border-radius: 24rpx;
  margin: 20rpx;
  padding: 30rpx;
}

.detail-title {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.detail-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.detail-imgs image {
  width: 100%;
  border-radius: 16rpx;
  margin-bottom: 15rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  border-top: 1rpx solid #eee;
}

.add-cart {
  width: 90%;
  height: 70rpx;
  background: #d4b9a8;
  color: #fff;
  text-align: center;
  line-height: 70rpx;
  border-radius: 35rpx;
  font-size: 28rpx;
}