.container{
  padding: 20rpx;
  background: #f5f5f7;
  min-height: 100vh;
}
.address-item{
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}
.top{
  display: flex;
  gap: 20rpx;
  margin-bottom: 15rpx;
}
.default{
  background: #007aff;
  color: #fff;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}
.detail{
  color: #666;
  margin-bottom: 20rpx;
}
.btns{
  display: flex;
  gap: 30rpx;
  color: #007aff;
}
.add-btn{
  position: fixed;
  bottom: 40rpx;
  left: 40rpx;
  right: 40rpx;
  background: #007aff;
  color: #fff;
  border-radius: 16rpx;
}