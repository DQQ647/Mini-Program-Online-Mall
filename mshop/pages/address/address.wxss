page {
  background: #f7f3f0;
  font-family: PingFangSC, sans-serif;
}
.container {
  padding: 30rpx;
}
.page-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #3d3530;
  margin-bottom: 30rpx;
}

.address-list {
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}
.address-item {
  padding: 25rpx 0;
  border-bottom: 1rpx solid #f0ebe6;
}
.address-item:last-child {
  border-bottom: none;
}
.address-top {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}
.name {
  font-size: 28rpx;
  color: #3d3530;
  font-weight: 500;
  margin-right: 20rpx;
}
.phone {
  font-size: 26rpx;
  color: #666;
}
.default-tag {
  background: #d4b9a8;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  margin-left: auto;
}
.address-detail {
  font-size: 26rpx;
  color: #888;
  line-height: 1.5;
  margin-bottom: 15rpx;
}
.address-actions {
  display: flex;
  justify-content: flex-end;
  gap: 30rpx;
}
.action-btn {
  font-size: 26rpx;
  color: #d4b9a8;
}
.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 26rpx;
}

.add-btn {
  background: #d4b9a8;
  color: #fff;
  border-radius: 24rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}
.add-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}