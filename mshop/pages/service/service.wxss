page {
  background: #f7f3f0;
  font-family: PingFangSC, sans-serif;
}
.container {
  padding: 30rpx;
}
.page-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #3d3530;
  margin-bottom: 30rpx;
}
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}
.item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 20rpx;
  border-bottom: 1rpx solid #f0ebe6;
}
.item:last-child {
  border-bottom: none;
}
.left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.icon {
  font-size: 32rpx;
}
.label {
  font-size: 28rpx;
  color: #3d3530;
}
.value {
  font-size: 28rpx;
  color: #d4b9a8;
}
.arrow {
  font-size: 28rpx;
  color: #d4b9a8;
}
.desc {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  font-size: 26rpx;
  color: #888;
  line-height: 1.7;
}