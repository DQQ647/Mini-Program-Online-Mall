.container{
  background: #f5f5f7;
  min-height: 100vh;
  padding: 40rpx;
}
.card{
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
}
.icon{
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 20rpx;
}
.title{
  font-size: 34rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}
.desc{
  font-size: 26rpx;
  color: #888;
  display: block;
  margin-bottom: 40rpx;
}
.phone{
  font-size: 36rpx;
  color: #007aff;
  font-weight: bold;
  margin-bottom: 50rpx;
}
.call-btn{
  background: #0071e3;
  color: #fff;
  border-radius: 16rpx;
}